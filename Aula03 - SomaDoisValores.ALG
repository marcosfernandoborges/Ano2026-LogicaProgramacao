Algoritmo "SOMA"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Solicita e soma dois valores.
// Autor(a)    : Marcos Fernando Borges
// Data atual  : 21/05/2026

Var
// Seçăo de Declaraçőes das variáveis 
v1, v2: inteiro
soma: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 

Escreval (" --------------- ")
Escreval (" SOMA DE VALORES ")
Escreval (" --------------- ")
Escreval ("")

         Escreva (" INSIRA O VALOR 01: ")
            Leia (v1)
            
         Escreva (" INSIRA O VALOR 02  ")
            Leia (v2)
            
            soma <- (v1 + v2)
         
         Escreval ("")
         Escreval (" ---------------------------- ")
         Escreval (" RESULTADO CALCULADO " , soma)
         Escreval (" ---------------------------- ")
         


Fimalgoritmo